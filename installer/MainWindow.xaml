<Window x:Class="GoldRushInstaller.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gold Rush Mod Menu Installer"
        Height="760" Width="580"
        MinHeight="760" MinWidth="580"
        WindowStartupLocation="CenterScreen"
        Background="#1A1A1E"
        Foreground="White"
        ResizeMode="CanMinimize">
    <Window.Resources>
        <Style x:Key="DarkButton" TargetType="Button">
            <Setter Property="Background" Value="#2A2A35"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#444455"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#3A3A4A"/></Trigger>
                            <Trigger Property="IsPressed"   Value="True"><Setter Property="Background" Value="#222230"/></Trigger>
                            <Trigger Property="IsEnabled"   Value="False"><Setter Property="Opacity" Value="0.4"/></Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource DarkButton}">
            <Setter Property="Background" Value="#1E4A1E"/>
            <Setter Property="BorderBrush" Value="#3A8A3A"/>
            <Style.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#2E6A2E"/></Trigger></Style.Triggers>
        </Style>
        <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource DarkButton}">
            <Setter Property="Background" Value="#4A1E1E"/>
            <Setter Property="BorderBrush" Value="#8A3030"/>
            <Style.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#6A2828"/></Trigger></Style.Triggers>
        </Style>
        <Style x:Key="WarnButton" TargetType="Button" BasedOn="{StaticResource DarkButton}">
            <Setter Property="Background" Value="#3A2E00"/>
            <Setter Property="BorderBrush" Value="#887722"/>
            <Setter Property="Foreground" Value="#FFD033"/>
            <Style.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#554400"/></Trigger></Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,14">
            <TextBlock Text="&#x26CF;  GOLD RUSH MOD MENU" FontSize="22" FontWeight="Bold"
                       Foreground="#FFD033" HorizontalAlignment="Center"/>
            <TextBlock Text="Installer &amp; Auto-Updater" FontSize="13" Foreground="#AAAACC"
                       HorizontalAlignment="Center" Margin="0,2,0,0"/>
        </StackPanel>

        <!-- DISCLAIMER -->
        <Border Grid.Row="1" Background="#220A0A" BorderBrush="#BB2222"
                BorderThickness="2" CornerRadius="6" Padding="14" Margin="0,0,0,14">
            <StackPanel>
                <TextBlock Text="&#x26A0;  IMPORTANT DISCLAIMER" FontSize="13" FontWeight="Bold"
                           Foreground="#FF4444" Margin="0,0,0,8"/>
                <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#FFAAAA" Margin="0,0,0,6">
                    <Run FontWeight="Bold">If you paid money for this mod — you were scammed.</Run>
                    <Run>This mod is and will always be completely FREE.</Run>
                </TextBlock>
                <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#FFDDAA" Margin="0,0,0,4">
                    <Run FontWeight="Bold">Official download source:</Run>
                </TextBlock>
                <TextBlock x:Name="RepoLinkText"
                           Text="https://github.com/kpteam/gold-rush-mod-menu"
                           FontSize="12" Foreground="#4499FF" Cursor="Hand"
                           TextDecorations="Underline" Margin="0,0,0,6"
                           MouseLeftButtonDown="RepoLink_Click"/>
                <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="#FFAAAA">
                    <Run FontWeight="Bold">If you downloaded this from anywhere other than the link above</Run>
                    <Run>— delete it immediately. Unofficial copies may contain viruses or malware.</Run>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- GAME PATH -->
        <Border Grid.Row="2" Background="#1E1E28" BorderBrush="#333344"
                BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="GAME FOLDER" FontSize="11" FontWeight="Bold" Foreground="#9999CC" Margin="0,0,0,6"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="GamePathBox" Grid.Column="0"
                             Background="#111118" Foreground="#DDDDFF" BorderBrush="#333344"
                             BorderThickness="1" Padding="6,4" FontSize="12" VerticalContentAlignment="Center"/>
                    <Button x:Name="BrowseButton" Grid.Column="2" Content="Browse..." Width="80"
                            Style="{StaticResource DarkButton}" Click="BrowseButton_Click"/>
                </Grid>
                <TextBlock x:Name="GamePathStatus" FontSize="11" Foreground="#AAAACC" Margin="0,6,0,0" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- VERSION INFO - MOD -->
        <Border Grid.Row="3" Background="#1E1E28" BorderBrush="#333344"
                BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="MOD INSTALLED" FontSize="11" Foreground="#9999CC"/>
                    <TextBlock x:Name="InstalledVersionText" Text="---" FontSize="16" FontWeight="Bold" Foreground="White"/>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="LATEST MOD ON GITHUB" FontSize="11" Foreground="#9999CC"/>
                    <TextBlock x:Name="LatestVersionText" Text="Checking..." FontSize="16" FontWeight="Bold" Foreground="#FFD033"/>
                </StackPanel>
                <Button x:Name="CheckUpdateButton" Grid.Column="2" Content="Check" Width="70"
                        Style="{StaticResource DarkButton}" Click="CheckUpdate_Click" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- VERSION INFO - INSTALLER -->
        <Border Grid.Row="4" Background="#1E1E28" BorderBrush="#333344"
                BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="INSTALLER VERSION" FontSize="11" Foreground="#9999CC"/>
                    <TextBlock x:Name="InstallerVersionText" Text="---" FontSize="16" FontWeight="Bold" Foreground="White"/>
                </StackPanel>
                <StackPanel Grid.Column="1">
                    <TextBlock Text="LATEST INSTALLER" FontSize="11" Foreground="#9999CC"/>
                    <TextBlock x:Name="LatestInstallerVersionText" Text="Checking..." FontSize="16" FontWeight="Bold" Foreground="#FFD033"/>
                </StackPanel>
                <Button x:Name="UpdateInstallerButton" Grid.Column="2" Content="Update" Width="70"
                        Style="{StaticResource WarnButton}" Click="UpdateInstaller_Click"
                        VerticalAlignment="Center" IsEnabled="False" ToolTip="A newer installer is available"/>
            </Grid>
        </Border>

        <!-- ACTION BUTTONS (2x2) -->
        <Grid Grid.Row="5" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="40"/>
            </Grid.RowDefinitions>
            <!-- Row 0: primary actions -->
            <Button x:Name="InstallButton" Grid.Row="0" Grid.Column="0" Content="⬇  Install / Update Mod"
                    Style="{StaticResource AccentButton}" FontSize="13" FontWeight="Bold"
                    Click="Install_Click"/>
            <Button x:Name="RemoveModButton" Grid.Row="0" Grid.Column="2" Content="✕  Remove Mod Only"
                    Style="{StaticResource DangerButton}" FontSize="13"
                    ToolTip="Removes only the mod DLL and config. BepInEx and all other files stay intact."
                    Click="RemoveMod_Click"/>
            <!-- Row 2: secondary actions -->
            <Button x:Name="UninstallButton" Grid.Row="2" Grid.Column="0" Content="☠  Full Uninstall (incl. BepInEx)"
                    Style="{StaticResource DangerButton}" FontSize="11"
                    ToolTip="Removes mod + BepInEx loader hook. Returns game to completely vanilla state."
                    Click="Uninstall_Click"/>
            <Button x:Name="OpenFolderButton" Grid.Row="2" Grid.Column="2" Content="📁  Open Game Folder"
                    Style="{StaticResource DarkButton}" FontSize="11"
                    Click="OpenFolder_Click"/>
        </Grid>

        <!-- LOG + PROGRESS -->
        <Border Grid.Row="6" Background="#1E1E28" BorderBrush="#333344"
                BorderThickness="1" CornerRadius="6" Padding="12">
            <StackPanel>
                <TextBlock Text="LOG" FontSize="11" FontWeight="Bold" Foreground="#9999CC" Margin="0,0,0,6"/>
                <ProgressBar x:Name="ProgressBar" Height="16" Minimum="0" Maximum="100"
                             Background="#111118" Foreground="#FFD033" BorderBrush="#333344"
                             BorderThickness="1" Margin="0,0,0,8" Visibility="Collapsed"/>
                <ScrollViewer x:Name="LogScroller" Height="150" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="LogText" FontFamily="Consolas" FontSize="11"
                               Foreground="#AAFFAA" TextWrapping="Wrap"/>
                </ScrollViewer>
            </StackPanel>
        </Border>

        <!-- FOOTER -->
        <TextBlock Grid.Row="7" Margin="0,8,0,0" TextAlignment="Center" FontSize="11" Foreground="#555566">
            <Run>Free and open source — MIT License  |  </Run>
            <Run Text="github.com/kpteam/gold-rush-mod-menu" Foreground="#4499FF"
                 TextDecorations="Underline" Cursor="Hand"/>
        </TextBlock>
    </Grid>
</Window>